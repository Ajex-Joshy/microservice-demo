{
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "./dist",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"target": "ES2022",
		"types": ["node"],
		"sourceMap": true,
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"paths": {
			"@domain/*": ["./src/domain/*"],
			"@application/*": ["./src/application/*"],
			"@infrastructure/*": ["./src/infrastructure/*"],
			"@interfaces/*": ["./src/interfaces/*"],
			"@shared/*": ["./src/shared/*"],
			"@config/*": ["./src/config/*"]
		}
	},
	"include": ["src/main.ts", "src/**/*.ts"]
}
