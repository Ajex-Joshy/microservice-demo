{
	"name": "order-service",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"dev": "tsx watch src/main.ts",
		"build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
		"start": "node dist/main.js",
		"lint": "biome check .",
		"format": "biome format .",
		"fix": "biome check --write .",
		"generate:proto": "proto-loader-gen-types --longs=String --enums=String --defaults --oneofs --grpcLib=@grpc/grpc-js --outDir=src/infrastructure/grpc/generated/ proto/*.proto"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "commonjs",
	"dependencies": {
		"@grpc/grpc-js": "^1.14.3",
		"@grpc/proto-loader": "^0.8.0",
		"@prisma/adapter-pg": "^7.7.0",
		"@prisma/client": "^7.7.0",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"grpc-health-check": "^2.1.0",
		"helmet": "^8.1.0",
		"inversify": "^8.1.0",
		"jsonwebtoken": "^9.0.3",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"prisma": "^7.7.0",
		"reflect-metadata": "^0.2.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/express": "^5.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"pino-pretty": "^13.1.3",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}
