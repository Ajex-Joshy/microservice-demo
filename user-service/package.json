{
  "name": "user-service",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npx tsx watch src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/src/main.js",
    "lint": "biome check .",
    "format": "biome format .",
